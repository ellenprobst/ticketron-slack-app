{
  "name": "bolt-js-ai-agent-template",
  "version": "1.0.0",
  "description": "A template for building AI-enabled Slack apps",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node app.js",
    "lint": "npx @biomejs/biome check *.js ai/ listeners/",
    "lint:fix": "npx @biomejs/biome check --write *.js ai/ listeners/"
  },
  "author": "Slack Technologies, LLC",
  "license": "MIT",
  "keywords": [
    "slack",
    "bolt",
    "slackapi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/slack-samples/bolt-js-assistant-template.git"
  },
  "bugs": {
    "url": "https://github.com/slack-samples/bolt-js-assistant-template/issues"
  },
  "dependencies": {
    "@google/adk": "^0.5.0",
    "@google/adk-devtools": "^0.5.0",
    "@slack/bolt": "^4.6.0",
    "dotenv": "~17.2.3",
    "openai": "^6.15.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@slack/cli-hooks": "^1.2.1",
    "@types/node": "^25.0.3",
    "openapi-types": "^12.1.3",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3"
  }
}
