SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
# SLACK_API_URL=YOUR_SLACK_API_URL
# This template uses OpenAI, but you can use any other provider!
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
# Jira credentials — used for direct REST API calls (no MCP required)
# JIRA_EMAIL / JIRA_API_TOKEN take precedence; ATLASSIAN_* are legacy fallbacks.
JIRA_EMAIL=bot@yourcompany.com
JIRA_API_TOKEN=YOUR_ATLASSIAN_API_TOKEN
# Legacy fallbacks (still accepted if JIRA_* are not set)
# ATLASSIAN_EMAIL=bot@yourcompany.com
# ATLASSIAN_API_TOKEN=YOUR_ATLASSIAN_API_TOKEN
